import { {{pascalCase name}}Service } from "./{{name}}.service";

const {{name}}Procedure = authedProcedure.use(({ context, next }) => {
	const {{name}}Service = new {{pascalCase name}}Service(
		context.db, 
		context.session.user.id
		);

	return next({
		context: {
