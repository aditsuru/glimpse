# ── Database ──────────────────────────────────────────────────────
# Local:        postgresql://postgres:postgres@localhost:5432/glimpse
# Staging/Prod: Neon connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/glimpse

# ── Redis (Upstash local emulator) ───────────────────────────────
# Local:        http://localhost:8079 + local_token
# Staging/Prod: Upstash REST URL + token
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local_token

# ── Storage ───────────────────────────────────────────────────────
# Local:        set S3_ENDPOINT, use MinIO credentials below
# Staging/Prod: remove S3_ENDPOINT, set real values for all of:
#               CLOUDFLARE_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY,
#               R2_BUCKET_NAME, R2_PUBLIC_URL
S3_ENDPOINT=http://localhost:9000
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=glimpse-dev
R2_PUBLIC_URL=http://localhost:9000/glimpse-dev

# ── Auth ──────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=any-random-string-for-local
BETTER_AUTH_URL=http://localhost:3000

# ── OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Cron (QStash) ────────────────────────────────────────────────
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=10s
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=10s

# ── Redis ─────────────────────────────────────────────────────────
REDIS_FEED_SEEN_MAX_ITEMS=500

# ── Pagination ────────────────────────────────────────────────────
POSTS_PAGINATION_LIMIT=10
COMMENTS_PAGINATION_LIMIT=10
PROFILE_PAGINATION_LIMIT=10

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POST_CHAR_LIMIT=300
NEXT_PUBLIC_BIO_CHAR_LIMIT=150
NEXT_PUBLIC_EMAIL_RESEND_TIMEOUT=60000

# ── React Query ───────────────────────────────────────────────────
NEXT_PUBLIC_QUERY_STALE_TIME=300000
NEXT_PUBLIC_QUERY_GC_TIME=300000
NEXT_PUBLIC_QUERY_MAX_RETRIES=1
