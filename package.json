{
	"name": "glimpse",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check --write",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"prepare": "husky",
		"email": "email dev --dir './src/emails'",
		"auth:generate": "bunx @better-auth/cli generate --config src/lib/server/auth.ts --output src/db/schema/auth-schema.ts"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json,jsonc,css}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1057.0",
		"@aws-sdk/s3-request-presigner": "^3.1057.0",
		"@base-ui/react": "^1.5.0",
		"@floating-ui/react": "^0.27.19",
		"@hookform/resolvers": "^5.4.0",
		"@neondatabase/serverless": "^1.1.0",
		"@orpc/client": "^1.14.4",
		"@orpc/next": "^0.27.0",
		"@orpc/server": "^1.14.4",
		"@orpc/tanstack-query": "^1.14.4",
		"@react-email/components": "^1.0.12",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.100.14",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.38.0",
		"@upstash/workflow": "^1.3.0",
		"better-auth": "^1.6.12",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^1.17.0",
		"motion": "^12.40.0",
		"ms": "^2.1.3",
		"nanoid": "^5.1.11",
		"next": "16.2.6",
		"next-themes": "^0.4.6",
		"obscenity": "0.4.6",
		"pg": "^8.21.0",
		"pino": "^10.3.1",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-hook-form": "^7.76.1",
		"react-icons": "^5.6.0",
		"react-snowfall": "^2.4.0",
		"resend": "^6.12.4",
		"shadcn": "^4.8.3",
		"sonner": "^2.0.7",
		"swr": "^2.4.1",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"use-debounce": "^10.1.1",
		"vaul": "^1.1.2",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@faker-js/faker": "^10.4.0",
		"@react-email/preview-server": "^5.2.10",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/ms": "^2.1.0",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"biome": "^0.3.3",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.6",
		"pino-pretty": "^13.1.3",
		"react-email": "6.1.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
}
